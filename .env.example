XCLAW_ENV=dev
XCLAW_HOST=0.0.0.0
XCLAW_PORT=8080
XCLAW_LOG_LEVEL=INFO

# MiroThinker / SGLang (OpenAI-compatible endpoint)
XCLAW_LLM_PROVIDER=mirothinker
XCLAW_LLM_BASE_URL=http://localhost:8000/v1
XCLAW_LLM_API_KEY=dummy
XCLAW_LLM_MODEL=mirothinker-30b

# Limits / strategy
XCLAW_REQUEST_TIMEOUT_SEC=300
XCLAW_MAX_AGENT_ITERATIONS=50
XCLAW_ENABLE_TOOL_CALLS=true

# Optional stores
XCLAW_REDIS_URL=redis://localhost:6379/0
XCLAW_CHROMA_PATH=./data/chroma

# Webhook secrets (fill before production)
XCLAW_FEISHU_ENCRYPT_KEY=
XCLAW_FEISHU_VERIFICATION_TOKEN=
XCLAW_TEAMS_APP_ID=
XCLAW_TEAMS_APP_PASSWORD=

